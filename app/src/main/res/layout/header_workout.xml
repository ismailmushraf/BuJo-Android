<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/bujo_background"
    android:descendantFocusability="beforeDescendants">
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:focusable="true"
        android:focusableInTouchMode="true" />
    <!-- SECTION 1: TIMER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/shape_bujo_box"
        android:padding="16dp"
        android:gravity="center">
        <Chronometer
            android:id="@+id/chronometer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="48sp"
            android:textColor="@color/bujo_text"
            android:textStyle="bold"/>
        <Button
            android:id="@+id/btn_timer_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="START SESSION" />
    </LinearLayout>

    <!-- SECTION 2: SET INPUT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        android:background="@drawable/shape_bujo_box"
        android:padding="12dp">

        <AutoCompleteTextView
            android:id="@+id/auto_exercise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Exercise Name"
            android:inputType="textCapWords"
            android:completionThreshold="2"
            android:background="@android:color/transparent"
            android:paddingBottom="8dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/bujo_divider"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp">

            <EditText
                android:id="@+id/et_weight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="numberDecimal"
                android:hint="Weight (0 if bodyweight)"
                android:textSize="14sp"
                android:background="@android:color/transparent"/>

            <EditText
                android:id="@+id/et_reps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="number"
                android:hint="Reps"
                android:textSize="14sp"
                android:background="@android:color/transparent"/>
        </LinearLayout>

        <EditText
            android:id="@+id/et_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Note for this round..."
            android:textSize="14sp"
            android:inputType="textCapSentences"
            android:background="@android:color/transparent"/>

        <Button
            android:id="@+id/btn_add_set"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:text="LOG SET" />
    </LinearLayout>

    <!-- SECTION 3: HEADER FOR THE LIST -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TODAY'S LOG"
        android:textStyle="bold"
        android:textColor="@color/bujo_text_secondary"
        android:layout_marginTop="16dp"
        android:paddingBottom="4dp"/>

</LinearLayout>