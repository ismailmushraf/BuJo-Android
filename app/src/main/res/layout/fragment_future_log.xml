<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:animateLayoutChanges="true"
    android:background="@color/bujo_background">

    <LinearLayout
        android:id="@+id/month_controls"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <Button
            android:id="@+id/btn_prev_month"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="&lt;" />

        <TextView
            android:id="@+id/tv_calendar_month"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/bujo_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_today"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TODAY" />

        <Button
            android:id="@+id/btn_next_month"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="&gt;" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#6D8E00" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:gravity="center_vertical">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Sun" android:textStyle="bold" android:textColor="@color/bujo_text" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Mon" android:textStyle="bold" android:textColor="@color/bujo_text" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Tue" android:textStyle="bold" android:textColor="@color/bujo_text" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Wed" android:textStyle="bold" android:textColor="@color/bujo_text" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Thu" android:textStyle="bold" android:textColor="@color/bujo_text" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Fri" android:textStyle="bold" android:textColor="@color/bujo_text" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Sat" android:textStyle="bold" android:textColor="@color/bujo_text" />
    </LinearLayout>

    <GridView
        android:id="@+id/grid_calendar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:horizontalSpacing="2dp"
        android:numColumns="7"
        android:padding="8dp"
        android:verticalSpacing="2dp" />

    <LinearLayout
        android:id="@+id/month_selected_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="8dp">

        <TextView
            android:id="@+id/tv_month_selected_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/bujo_text"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_week_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/bujo_text_secondary"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/agenda_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Row 3: Dates Grid Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <GridView
                android:id="@+id/grid_week"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:horizontalSpacing="0dp"
                android:numColumns="7"
                android:scrollbars="none"
                android:verticalSpacing="0dp" />
        </LinearLayout>

        <!-- Top Divider Line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/bujo_divider" />

        <!-- Clickable Selected Date Banner -->
        <LinearLayout
            android:id="@+id/layout_selected_date_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tv_selected_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/bujo_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Clean Text-Based Arrow Symbol -->
            <TextView
                android:id="@+id/tv_expand_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/bujo_text_secondary"
                android:textSize="14sp"
                android:paddingLeft="8dp" />

        </LinearLayout>

        <!-- Bottom Divider Line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/bujo_divider" />

        <!-- Agenda List Element -->
        <ListView
            android:id="@+id/list_agenda"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@color/bujo_divider"
            android:dividerHeight="1dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_migrated_items"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="MIGRATED ITEMS" />

</LinearLayout>
