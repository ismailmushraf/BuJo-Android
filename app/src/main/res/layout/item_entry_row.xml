<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground"> <!-- Adds touch feedback -->

    <!-- Polished Signifier UI -->
    <TextView
        android:id="@+id/row_signifier"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/shape_bujo_box"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="#333333"
        android:textStyle="bold"/>

    <!-- Content -->
    <TextView
        android:id="@+id/row_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="12dp"
        android:textSize="18sp"
        android:textColor="#111111"/>

    <!-- Tag -->
    <TextView
        android:id="@+id/row_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#0066CC"
        android:background="#E6F2FF"
        android:padding="4dp"
        android:visibility="gone"/>
</LinearLayout>