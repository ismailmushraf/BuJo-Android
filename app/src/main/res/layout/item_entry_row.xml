<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <!-- Polished Signifier UI -->
    <TextView
        android:id="@+id/row_signifier"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:textSize="20sp"
        android:textColor="@color/bujo_box_border" />

    <!-- Content & Optional Deadline -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="1"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="12dp">

        <TextView
            android:id="@+id/row_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textColor="@color/bujo_text"/>

        <TextView
            android:id="@+id/row_deadline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/bujo_text_secondary"
            android:layout_marginTop="2dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Tag -->
    <TextView
        android:id="@+id/row_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#0066CC"
        android:background="#E6F2FF"
        android:padding="4dp"
        android:visibility="gone"/>
</LinearLayout>
